{
  "manifest_version": 3,
  "name": "LinkedIn Job Copy Agent",
  "version": "0.1.0",
  "description": "Copy LinkedIn job listing details as structured prompts for ChatGPT, Codex, Claude, and Claude Code.",
  "permissions": ["clipboardWrite"],
  "host_permissions": [
    "https://www.linkedin.com/jobs/*",
    "https://linkedin.com/jobs/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://linkedin.com/jobs/*"
      ],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "LinkedIn Job Copy Agent"
  }
}
